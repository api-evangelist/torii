              {
                "name": "size",
                "value": "",
                "type": "query",
                "description": "Number of results per page (max 1000)."
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Cursor for pagination to retrieve the next page of results."
