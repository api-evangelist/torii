{
  "opencollection": "1.0.0",
  "info": {
    "name": "Torii API",
    "version": "1.1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Apps",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Torii List apps",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.toriihq.com/v1.0/apps",
            "headers": [
              {
                "name": "X-API-Version",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "fields",
                "value": "",
                "type": "query",
                "description": "Comma-separated list of fields to include in the response (e.g. id,name,category)."
              },
              {
                "name": "state",
                "value": "",
                "type": "query",
                "description": "Filter apps by state (e.g. discovered, managed, closed)."
              },
              {
                "name": "sort",
                "value": "",
                "type": "query",
                "description": "Field to sort results by."
              },
              {
                "name": "size",
                "value": "",
                "type": "query",
                "description": "Number of results per page."
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Cursor for pagination to retrieve the next page of results."
              }
            ]
          },
          "docs": "Returns a list of apps used in the organization. Supports filtering via query parameters including custom application fields."
        }
      ]
    },
    {
      "info": {
        "name": "Metadata",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Torii List app fields metadata",
