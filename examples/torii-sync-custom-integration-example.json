{
  "title": "Torii Sync Custom Integration - Example",
  "description": "Example of syncing custom application user and license data into Torii via POST /services/sync/custom.",
  "request": {
    "method": "POST",
    "url": "https://api.toriihq.com/v1.0/services/sync/custom",
    "headers": {
      "Authorization": "Bearer {TORII_API_KEY}",
      "Content-Type": "application/json",
      "X-API-Version": "1.1"
    },
    "body": {
      "appName": "Internal Analytics Dashboard",
      "users": [
        {
          "email": "alice@company.com",
          "status": "active",
          "role": "admin",
          "lastUsedDate": "2026-05-01T14:30:00Z"
        },
        {
          "email": "bob@company.com",
          "status": "active",
          "role": "viewer",
          "lastUsedDate": "2026-04-28T10:15:00Z"
        },
        {
          "email": "charlie@company.com",
          "status": "inactive",
          "role": "viewer",
          "lastUsedDate": "2026-01-10T08:00:00Z"
        }
      ],
      "licenses": [
        {
          "name": "Admin License",
          "total": 5,
          "used": 1,
          "pricePerUser": 500
        },
        {
          "name": "Viewer License",
          "total": 50,
          "used": 42,
          "pricePerUser": 100
        }
      ]
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "status": "ok"
    }
  }
}
